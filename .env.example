# =============================================================================
# ZenSynora (MyClaw) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are optional — ZenSynora can run with config.json alone.
# Environment variables override config.json values at runtime.
#
# 🐳 Docker Usage:
#   This file is automatically loaded by docker-compose.yml via the `env_file:`
#   directive. When running in Docker, the following additional vars are set:
#     ZENSYNORA_DOCKER=true        # Indicates containerized environment
#     MYCLAW_CONFIG_DIR=/data/.myclaw  # Persisted via Docker volume
#
#   To use Docker:
#     1. cp .env.example .env
#     2. Edit .env with your credentials
#     3. docker compose up --build
# =============================================================================

# ── LLM Provider API Keys ────────────────────────────────────────────────────
# At least one provider is required. Uncomment and set the ones you use.

# OpenAI / LM Studio / llama.cpp / Groq / OpenRouter
# MYCLAW_OPENAI_API_KEY=sk-...

# Anthropic Claude
# MYCLAW_ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# MYCLAW_GEMINI_API_KEY=...

# ── Local Provider URLs ──────────────────────────────────────────────────────
# Override default localhost URLs for remote/local LLM servers

# Ollama (default: http://localhost:11434)
# MYCLAW_OLLAMA_BASE_URL=http://localhost:11434

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Get your token from @BotFather: https://t.me/botfather
# MYCLAW_TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ── WhatsApp Business Cloud API ──────────────────────────────────────────────
# Requires Meta Business account. See docs/dev/plans/whatsapp_implementation_plan.md

# MYCLAW_WHATSAPP_PHONE_NUMBER_ID=123456789012345
# MYCLAW_WHATSAPP_BUSINESS_ACCOUNT_ID=987654321098765
# MYCLAW_WHATSAPP_ACCESS_TOKEN=EAA...
# MYCLAW_WHATSAPP_VERIFY_TOKEN=myclaw_verify_123

# ── Agent Defaults ───────────────────────────────────────────────────────────
# Override the default model and provider

# MYCLAW_DEFAULT_PROVIDER=ollama
# MYCLAW_DEFAULT_MODEL=llama3.2

# ── Agent Swarm ──────────────────────────────────────────────────────────────
# MYCLAW_SWARM_ENABLED=true
# MYCLAW_MAX_CONCURRENT_SWARMS=3
# MYCLAW_SWARM_TIMEOUT=300

# ── Timeouts ─────────────────────────────────────────────────────────────────
# MYCLAW_SHELL_TIMEOUT=30
# MYCLAW_LLM_TIMEOUT=60
# MYCLAW_HTTP_TIMEOUT=30

# ── Memory Management ────────────────────────────────────────────────────────
# MYCLAW_MEMORY_CLEANUP_DAYS=30
# MYCLAW_MEMORY_VACUUM_THRESHOLD=1000
# MYCLAW_AGENTS_SUMMARIZATION_THRESHOLD=50

# ── Knowledge Base ───────────────────────────────────────────────────────────
# MYCLAW_KNOWLEDGE_AUTO_EXTRACT=true

# ── New Tech Tracking ────────────────────────────────────────────────────────
# MYCLAW_GITHUB_TOKEN=ghp_...
# MYCLAW_GITHUB_REPO_OWNER=yourusername
# MYCLAW_GITHUB_REPO_NAME=yourrepo

# ── Semantic Cache ───────────────────────────────────────────────────────────
# MYCLAW_SEMANTIC_CACHE_ENABLED=true
# MYCLAW_SEMANTIC_CACHE_MAX_SIZE=1000
# MYCLAW_SEMANTIC_CACHE_TTL=3600
# MYCLAW_SEMANTIC_CACHE_SIMILARITY=0.85

# ── Worker Pool ──────────────────────────────────────────────────────────────
# MYCLAW_WORKER_POOL_MAX_WORKERS=10
# MYCLAW_WORKER_POOL_TASK_TIMEOUT=60
# MYCLAW_WORKER_POOL_QUEUE_SIZE=100

# ── Sandbox ──────────────────────────────────────────────────────────────────
# MYCLAW_SANDBOX_ENABLED=false
# MYCLAW_SANDBOX_MAX_MEMORY_MB=512
# MYCLAW_SANDBOX_MAX_TIME_SECONDS=30
# MYCLAW_SANDBOX_ALLOW_NETWORK=false

# ── Log Rotation ─────────────────────────────────────────────────────────────
# MYCLAW_LOG_ROTATION_MAX_SIZE_MB=10
# MYCLAW_LOG_ROTATION_MAX_AGE_DAYS=30
# MYCLAW_LOG_ROTATION_MAX_FILES=5
# MYCLAW_LOG_ROTATION_COMPRESS=true

# ── Intelligence Platform ────────────────────────────────────────────────────
# MYCLAW_RESEARCH_ENABLED=true
# MYCLAW_RESEARCH_INTERVAL=6
# MYCLAW_RESEARCH_IDLE=15
# MYCLAW_INTELLIGENT_ROUTING=true
# MYCLAW_BENCHMARKING_ENABLED=true

# ── Intelligent Routing ──────────────────────────────────────────────────────
# MYCLAW_ROUTING_ENABLED=true
# MYCLAW_ROUTING_PREFER_FREE=true
# MYCLAW_ROUTING_ALLOWED_MODELS=gpt-4o,claude-3-5-sonnet,llama3.2
# MYCLAW_ROUTING_ALLOWED_PROVIDERS=ollama,openai,anthropic

# ── Backends / SSH ───────────────────────────────────────────────────────────
# MYCLAW_SSH_HOST=192.168.1.100
# MYCLAW_SSH_USER=admin
# MYCLAW_SSH_KEY_PATH=~/.ssh/id_rsa

# ── Infrastructure ───────────────────────────────────────────────────────────
# Redis URL for multi-worker state sharing (Phase 6.1)
# ZEN_REDIS_URL=redis://localhost:6379/0

# ── Logging ──────────────────────────────────────────────────────────────────
# Control log level and format via environment
# MYCLAW_LOG_LEVEL=INFO
# MYCLAW_LOG_JSON=false

# ── Speech-to-Text (Optional) ────────────────────────────────────────────────
# VOSK_MODEL_PATH=./model

# ── Development ──────────────────────────────────────────────────────────────
# These are used during development and testing
# PYTHONPATH=.
# PYTEST_CURRENT_TEST=1
